{
	"name": "kamellion-dev/laravel-checkpoint",
	"description": "Simple Laravel development checkpoints for databases and local filesystem disks.",
	"type": "library",
	"license": "MIT",
	"keywords": [
		"laravel",
		"checkpoint",
		"database",
		"development",
		"artisan"
	],
	"homepage": "https://github.com/Kamellion-Dev/laravel-checkpoint",
	"support": {
		"issues": "https://github.com/Kamellion-Dev/laravel-checkpoint/issues",
		"source": "https://github.com/Kamellion-Dev/laravel-checkpoint"
	},
	"require": {
		"php": "^8.1",
		"illuminate/console": "^10.0|^11.0|^12.0",
		"illuminate/contracts": "^10.0|^11.0|^12.0",
		"illuminate/database": "^10.0|^11.0|^12.0",
		"illuminate/filesystem": "^10.0|^11.0|^12.0",
		"illuminate/support": "^10.0|^11.0|^12.0"
	},
	"autoload": {
		"psr-4": {
			"KamellionDev\\LaravelCheckpoint\\": "src/"
		}
	},
	"extra": {
		"laravel": {
			"providers": [
				"KamellionDev\\LaravelCheckpoint\\LaravelCheckpointServiceProvider"
			]
		}
	},
	"minimum-stability": "stable",
	"prefer-stable": true
}
